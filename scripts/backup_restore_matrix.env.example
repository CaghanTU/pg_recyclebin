# Copy to backup_restore_matrix.env and adjust (do not commit secrets).
# shellcheck disable=SC2034

# PostgreSQL (örnek: pgrx local)
export PGHOST="${PGHOST:-/home/$USER/.pgrx}"
export PGPORT="${PGPORT:-28817}"
export PGUSER="${PGUSER:-postgres}"
export PGDATABASE="${PGDATABASE:-testdb}"

# pgBackRest
export PGFB_STANZA="${PGFB_STANZA:-testdb}"
export PGFB_REPO_PATH="${PGFB_REPO_PATH:-/var/lib/pgbackrest}"
export PGFB_PGBACKREST_BIN="${PGFB_PGBACKREST_BIN:-/usr/local/bin/pgbackrest}"
export PGFB_PG_BIN="${PGFB_PG_BIN:-/usr/local/pgsql-17/bin}"

# pg_recyclebin GUC’lar (restore sırasında SET ile kullanılır)
export PGFB_TEMP_DIR="${PGFB_TEMP_DIR:-/tmp/pgfb_matrix_restore}"

# Hedef veri boyutu (GB). 0.05 = ~50MB hızlı smoke; 10 = tam matris yükü
export PGFB_TARGET_GB="${PGFB_TARGET_GB:-0.05}"

# Şifreli repo testi: 1 yapınca backup öncesi pgbackrest.conf’a cipher eklemen gerekir (README’ye bak)
export PGFB_ENCRYPTED_REPO="${PGFB_ENCRYPTED_REPO:-0}"
# Repo cipher pass (pgBackRest repo1-cipher-pass ile aynı olmalı)
export PGFB_CIPHER_PASS="${PGFB_CIPHER_PASS:-}"

# WAL replay matris adımında kullanılsın mı (false = daha hızlı; true = archive gerekir)
export PGFB_SKIP_WAL_REPLAY="${PGFB_SKIP_WAL_REPLAY:-true}"
